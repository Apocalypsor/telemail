{
  "name": "telemail",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "author": "Apocalypsor <chthon605@gmail.com>",
  "scripts": {
    "dev:worker": "pnpm --filter telemail-worker dev",
    "typegen:worker": "pnpm --filter telemail-worker typegen",
    "migrate:worker": "pnpm --filter telemail-worker migrate",
    "deploy:worker": "pnpm --filter telemail-worker deploy",
    "dev:page": "pnpm --filter telemail-page dev",
    "build:page": "pnpm --filter telemail-page build",
    "check": "biome check --no-errors-on-unmatched --files-ignore-unknown=true",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky",
    "skills:install": "pnpm dlx skills experimental_install && ln -sf ../.agents/skills .claude/",
    "skills:update": "pnpm dlx skills update"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "wrangler": "^4.80.0"
  },
  "lint-staged": {
    "*": [
      "biome check --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  }
}
