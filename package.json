{
  "name": "telemail",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "author": "Apocalypsor <chthon605@gmail.com>",
  "workspaces": [
    "apps/worker",
    "apps/page"
  ],
  "scripts": {
    "dev:worker": "bun --filter telemail-worker dev",
    "dev:cookie": "bun --filter telemail-worker dev:cookie",
    "dev:seed": "bun --filter telemail-worker dev:seed",
    "typegen:worker": "bun --filter telemail-worker typegen",
    "migrate:worker:local": "bun --filter telemail-worker migrate:local",
    "migrate:worker:remote": "bun --filter telemail-worker migrate:remote",
    "deploy:worker": "bun --filter telemail-worker deploy",
    "dev:page": "bun --filter telemail-page dev",
    "build:page": "bun --filter telemail-page build",
    "deploy:page": "bun --filter telemail-page deploy",
    "check": "biome check --no-errors-on-unmatched --files-ignore-unknown=true",
    "typecheck": "bun --cwd apps/page generate:routes && tsc -b --noEmit",
    "prepare": "husky",
    "skills:install": "bunx skills experimental_install && mkdir -p .claude/ && ln -sf ../.agents/skills .claude/",
    "skills:update": "bunx skills update"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.0",
    "typescript": "^6.0.0",
    "wrangler": "^4.85.0"
  },
  "lint-staged": {
    "*": [
      "biome check --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  }
}
