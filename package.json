{
  "name": "telemail",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "author": "Apocalypsor <chthon605@gmail.com>",
  "scripts": {
    "build:css": "node scripts/build-css.mjs",
    "build:web": "pnpm --filter telemail-web build",
    "deploy": "pnpm run build:css && wrangler deploy",
    "dev": "pnpm run build:css && wrangler dev",
    "dev:web": "pnpm --filter telemail-web dev",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "migrate": "wrangler d1 migrations apply gmail-tg-bridge --remote",
    "typecheck": "tsc --noEmit && pnpm --filter telemail-web typecheck",
    "check": "biome check --no-errors-on-unmatched --files-ignore-unknown=true",
    "prepare": "husky",
    "skills:install": "pnpm dlx skills experimental_install && ln -sf ../.agents/skills .claude/",
    "skills:update": "pnpm dlx skills update"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@cloudflare/vitest-pool-workers": "^0.13.3",
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "~4.1.0",
    "wrangler": "^4.80.0"
  },
  "lint-staged": {
    "*": [
      "biome check --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "dependencies": {
    "grammy": "^1.41.1",
    "hono": "^4.12.14",
    "i18next": "^26.0.1",
    "ky": "^1.14.3",
    "linkedom": "^0.18.12",
    "postal-mime": "^2.7.4",
    "turndown": "^7.2.2",
    "workers-observability-hub": "^1.0.3"
  }
}
