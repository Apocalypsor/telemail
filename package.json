{
	"name": "telemail",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"build:css": "node scripts/build-css.mjs",
		"deploy": "pnpm run build:css && wrangler deploy",
		"dev": "pnpm run build:css && wrangler dev",
		"start": "wrangler dev",
		"test": "vitest",
		"cf-typegen": "wrangler types",
		"migrate": "wrangler d1 migrations apply gmail-tg-bridge --remote",
		"prepare": "husky",
		"skills:install": "bunx skills experimental_install && ln -sf ../.agents/skills .claude/",
		"skills:update": "bunx skills update"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.13.3",
		"@tailwindcss/cli": "^4.2.2",
		"@types/node": "^25.5.0",
		"@types/turndown": "^5.0.6",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"typescript": "^5.9.3",
		"vitest": "~4.1.0",
		"wrangler": "^4.76.0"
	},
	"lint-staged": {
		"*.{ts,tsx}": "prettier --write",
		"*.{json,md}": "prettier --write"
	},
	"dependencies": {
		"grammy": "^1.41.1",
		"hono": "^4.12.8",
		"ky": "^1.14.3",
		"linkedom": "^0.18.12",
		"postal-mime": "^2.7.4",
		"turndown": "^7.2.2"
	}
}
