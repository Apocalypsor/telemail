{
  "name": "telemail-middleware",
  "version": "1.0.0",
  "description": "IMAP middleware bridge for Telemail",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "bun build --compile --minify-whitespace --minify-syntax --outfile server src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "elysia": "^1.4.28",
    "imapflow": "^1.2.16",
    "ky": "^1.14.3",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
