{
  "name": "telemail-page",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun generate:routes && tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler pages deploy dist --project-name=telemail-web --branch=main",
    "generate:routes": "tsr generate",
    "typecheck": "bun generate:routes && tsc -b --noEmit"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.9",
    "@sinclair/typebox": "^0.34.49",
    "@heroui/react": "^3.0.3",
    "@heroui/styles": "^3.0.3",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-router": "^1.168.24",
    "elysia": "^1.4.28",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/router-cli": "^1.166.36",
    "@tanstack/router-plugin": "^1.167.27",
    "@telegram-apps/sdk-react": "^3.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.2.4",
    "vite": "^6.4.2",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
